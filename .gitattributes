# Unity recommended line endings
* text=auto

# Force Unix line endings for text files
*.cs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf
*.compute text eol=lf
*.unity text eol=lf merge=unityyamlmerge
*.prefab text eol=lf merge=unityyamlmerge
*.asset text eol=lf merge=unityyamlmerge
*.meta text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.md text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.ai binary
*.pdf binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.fbx binary
*.blend binary
*.obj binary
*.ttf binary
*.otf binary
*.dll binary
*.so binary
*.a binary
*.lib binary
*.exe binary
